/*
 * Formae Plugin Manifest — GitHub
 *
 * This file defines metadata for the Formae GitHub plugin.
 */

// Plugin name used as the directory name and binary name.
name = "github"

// Plugin version following semver.
version = "0.1.0"

// Namespace appears in resource type IDs as the prefix: <Namespace>::<Module>::<Resource>.
namespace = "GitHub"

// One-line summary shown in `formae plugin list/info` output.
summary = "Manage GitHub repositories, teams, branch protection, and CI/CD configuration"

// Longer description shown on the plugin's Hub listing.
description = "Formae resource plugin for GitHub — manage repositories, branch protection, teams, team membership and repository access, and Actions secrets, variables, and workflow runs."

// Category for the plugin directory listing.
category = "cicd"

// SPDX license identifier (must be one of: Apache-2.0, BSD-3-Clause, MIT, MPL-2.0 for Hub publishability).
license = "Apache-2.0"

// Minimum compatible formae agent version.
minFormaeVersion = "0.87.0"

output {
  renderer = new JsonRenderer {}
}
