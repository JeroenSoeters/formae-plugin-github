module github.actions.secret

import "../github.pkl"
import "@formae/formae.pkl"

const type = "GitHub::Actions::Secret"

@github.ResourceHint {
    type = module.type
    identifier = "compositeId"
}
open class Secret extends formae.Resource {
    /// Repository owner.
    @github.FieldHint { createOnly = true }
    owner: String

    /// Repository name.
    @github.FieldHint { createOnly = true }
    repo: String

    /// Secret name (uppercase letters, digits, and underscores only).
    @github.FieldHint { createOnly = true }
    name: String

    /// Secret value. Write-only: cannot be read back from the API.
    @github.FieldHint { writeOnly = true }
    value: String
}
