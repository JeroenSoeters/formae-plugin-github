/*
 * Conformance Test: Replace Secret
 *
 * Changes the createOnly `name` field to trigger resource replacement.
 * Formae should delete the existing secret and create a new one.
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@github/github.pkl"
import "@github/actions/secret.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID").toUpperCase()
local testOwner = read("env:GITHUB_TEST_OWNER")
local testRepo = read("env:GITHUB_TEST_REPO")
local stackName = "plugin-sdk-test-secret-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for GitHub Actions Secret"
  }

  new formae.Target {
    label = "github-target"
    config = new github.Config {}
  }

  new secret.Secret {
    label = "plugin-sdk-test-secret"
    owner = testOwner
    repo = testRepo
    name = "FORMAE_TEST_\(testRunID)_REPLACED"  // CHANGED - triggers replacement
    value = "test-secret-value"
  }
}
